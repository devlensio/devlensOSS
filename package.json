{
  "name": "devlens",
  "version": "0.2.1",
  "workspaces": ["frontend"],
  "scripts": {
    "dev": "concurrently --names engine,frontend --prefix-colors cyan,magenta \"bun run dev:engine\" \"bun run dev:frontend\"",
    "dev:engine": "bun --watch src/server/index.ts",
    "dev:frontend": "cd frontend && bun run dev"
  },
  "dependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "devlensio": "^0.3.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}